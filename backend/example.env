PORT=5000
# Update just the MONGODB_URI line
(Get-Content ".env") -replace "MONGODB_URI=.*", "MONGODB_URI=" | Set-Content ".env"
```

Then run the server again — you should see:
```
Server running on port 5000 in development mode
MongoDB Connected: cluster0.xxxxx.mongodb.net
JWT_SECRET=mysupersecretjwtkey1234567890abc
JWT_EXPIRES_IN=7d
AES_SECRET_KEY=myaesencryptionkey12345678901234
NODE_ENV=development
FRONTEND_URL=http://localhost:3000